{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "public", "-p", "3000"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "vercel-dev",
      "runtimeExecutable": "vercel",
      "runtimeArgs": ["dev", "--listen", "3000"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
