{
  "version": 2,
  "crons": [
    { "path": "/api/reminders?action=send-due", "schedule": "0 * * * *" },
    { "path": "/api/reminders?action=daily-schedule", "schedule": "0 19 * * *" },
    { "path": "/api/reminders?action=prompt-confirmations", "schedule": "15 * * * *" },
    { "path": "/api/reminders?action=auto-confirm", "schedule": "45 * * * *" },
    { "path": "/api/ical-sync", "schedule": "*/15 * * * *" },
    { "path": "/api/offers?action=expire-offers", "schedule": "30 * * * *" },
    { "path": "/api/cron-payouts", "schedule": "0 9 * * 5" },
    { "path": "/api/setmore-sync", "schedule": "*/15 * * * *" },
    { "path": "/api/setmore-welcome", "schedule": "0 10 * * *" },
    { "path": "/api/cron-retention", "schedule": "0 3 * * 0" },
    { "path": "/api/cron-auto-complete", "schedule": "15 * * * *" },
    { "path": "/api/cron-reconcile-payments", "schedule": "30 * * * *" },
    { "path": "/api/cron-referral-rewards", "schedule": "0 4 * * *" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "coachcarter-website.vercel.app" }],
      "destination": "https://coachcarter.uk/$1",
      "permanent": true
    },
    {
      "source": "/classroom.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/classroom",
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/r/:code", "destination": "/api/r?code=:code" },
    { "source": "/book/:slug", "destination": "/learner/book.html" },
    { "source": "/:path*", "destination": "/public/:path*" }
  ]
}
