{
  "version": 2,
  "crons": [
    { "path": "/api/qa-digest", "schedule": "0 8 * * *" },
    { "path": "/api/reminders?action=send-due", "schedule": "0 * * * *" },
    { "path": "/api/reminders?action=daily-schedule", "schedule": "0 19 * * *" },
    { "path": "/api/reminders?action=prompt-confirmations", "schedule": "15 * * * *" },
    { "path": "/api/reminders?action=auto-confirm", "schedule": "45 * * * *" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "coachcarter-website.vercel.app" }],
      "destination": "https://coachcarter.co.uk/$1",
      "permanent": true
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
